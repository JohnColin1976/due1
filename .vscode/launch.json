{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug (J-Link, ATSAM3X8E)",
      "type": "cortex-debug",
      "request": "launch",
      "servertype": "jlink",

      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/build/due_app.elf",

      "device": "ATSAM3X8E",
      "interface": "swd",

      "serverpath": "JLinkGDBServerCLExe",

      "armToolchainPath": "/usr/bin",
      "gdbPath": "/usr/bin/gdb-multiarch",

      "serverArgs": [
        "-speed", "4000",
        "-singlerun"
      ],

      "runToEntryPoint": "main",
      "preLaunchTask": "Build (due1)",
      "svdFile": "${workspaceFolder}/svd/SAM3X8E.svd"
    },
    {
      "name": "Debug BL (J-Link, ATSAM3X8E)",
      "type": "cortex-debug",
      "request": "launch",
      "servertype": "jlink",

      "cwd": "${workspaceFolder}",
      "executable": "${workspaceFolder}/build/due_bootloader.elf",

      "device": "ATSAM3X8E",
      "interface": "swd",

      "serverpath": "JLinkGDBServerCLExe",

      "armToolchainPath": "/usr/bin",
      "gdbPath": "/usr/bin/gdb-multiarch",

      "serverArgs": [
        "-speed", "4000",
        "-singlerun"
      ],

      "runToEntryPoint": "main",
      "preLaunchTask": "Build (due1)",
      "svdFile": "${workspaceFolder}/svd/SAM3X8E.svd"
    }
  ]
}
